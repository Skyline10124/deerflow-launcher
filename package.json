{
  "name": "deerflow-launcher",
  "version": "0.4.1-bun",
  "description": "DeerFlow Desktop Launcher - Service management and startup (Bun-powered)",
  "main": "src/main.ts",
  "bin": {
    "deerflow-launcher": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/main.ts",
    "start:dev": "bun run --watch src/main.ts",
    "cli": "bun run src/cli.ts",
    "dev": "bun run --watch src/main.ts",
    "clean": "bun run src/main.ts --clean",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "build": "bun build src/cli.ts src/main.ts --outdir=dist --target=bun",
    "build:release": "bun run scripts/build-release.ts",
    "build:release:current": "bun run scripts/build-release.ts --current",
    "build:win": "bun run scripts/build-release.ts win",
    "build:linux": "bun run scripts/build-release.ts linux",
    "build:mac": "bun run scripts/build-release.ts macos"
  },
  "keywords": [
    "deerflow",
    "launcher",
    "bun",
    "process-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "inquirer": "^12.6.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bun": "latest",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "archiver": "^7.0.1",
    "eslint": "^9.22.0",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
