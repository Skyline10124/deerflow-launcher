{
  "name": "deerflow-launcher",
  "version": "0.4.4-alpha",
  "description": "DeerFlow Desktop Launcher - Service management and startup",
  "type": "module",
  "main": "dist/src/main.js",
  "bin": {
    "deerflow-launcher": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node src/main.ts",
    "cli": "node dist/src/cli.js",
    "dev": "ts-node-dev --respawn src/main.ts",
    "clean": "node dist/src/main.js --clean",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "build:pkg": "node scripts/build-pkg.js",
    "build:win": "node scripts/build-pkg.js win",
    "build:linux": "node scripts/build-pkg.js linux",
    "build:mac": "node scripts/build-pkg.js macos",
    "build:all": "node scripts/build-pkg.js",
    "tui:demo": "tsx src/tui/demo.tsx"
  },
  "keywords": [
    "deerflow",
    "launcher",
    "pm2",
    "process-manager"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@pm2/io": "^5.0.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^8.2.7",
    "ora": "^5.4.1",
    "pm2": "^6.0.14",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^14.3.1",
    "@types/inquirer": "^8.2.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "archiver": "^7.0.1",
    "eslint": "^9.22.0",
    "globals": "^17.4.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pkg": {
    "targets": [
      "node22-win-x64",
      "node22-linux-x64",
      "node22-macos-x64"
    ],
    "outputPath": "dist/bin",
    "assets": [
      "scripts/**/*",
      "node_modules/react/**/*",
      "node_modules/react-dom/**/*",
      "node_modules/react-reconciler/**/*",
      "node_modules/scheduler/**/*",
      "node_modules/ink/**/*",
      "node_modules/ink-spinner/**/*",
      "node_modules/ink-text-input/**/*",
      "node_modules/yoga-layout/**/*",
      "node_modules/yoga-layout-prebuilt/**/*",
      "node_modules/chalk/**/*",
      "node_modules/ansi-styles/**/*",
      "node_modules/supports-color/**/*",
      "node_modules/prop-types/**/*",
      "node_modules/arrify/**/*",
      "node_modules/lodash.throttle/**/*",
      "node_modules/log-update/**/*",
      "node_modules/is-ci/**/*",
      "node_modules/cli-boxes/**/*",
      "node_modules/ansi-escapes/**/*",
      "node_modules/cli-cursor/**/*",
      "node_modules/restore-cursor/**/*",
      "node_modules/onetime/**/*",
      "node_modules/signal-exit/**/*",
      "node_modules/strip-ansi/**/*",
      "node_modules/ansi-regex/**/*",
      "node_modules/string-width/**/*",
      "node_modules/emoji-regex/**/*",
      "node_modules/is-fullwidth-code-point/**/*",
      "node_modules/wrap-ansi/**/*",
      "node_modules/pm2/**/*",
      "node_modules/@pm2/**/*",
      "node_modules/pm2-axon/**/*",
      "node_modules/pm2-deploy/**/*",
      "node_modules/pm2-multimeter/**/*",
      "node_modules/nssocket/**/*",
      "node_modules/axon/**/*"
    ],
    "scripts": [
      "dist/src/**/*.js",
      "node_modules/ink/build/**/*.js",
      "node_modules/yoga-layout/dist/**/*.js",
      "node_modules/chalk/source/**/*.js"
    ]
  }
}
